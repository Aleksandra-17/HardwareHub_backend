# Docker Compose environment variables
# Copy to .env and adjust. Used for variable substitution in docker-compose.yml
# Env vars are also passed to fastapi-app container for config (no config.ini needed)

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fastapi_db
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Ports
PORT=8000
NGINX_PORT=80
NGINX_SSL_PORT=443
